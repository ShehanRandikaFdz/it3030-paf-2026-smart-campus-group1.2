  },
  "item": [
    {
      "name": "1. Create Resource (201)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Role", "value": "ADMIN" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Computer Lab 01\",\n  \"type\": \"LAB\",\n  \"capacity\": 60,\n  \"location\": \"Block A, Floor 1\",\n  \"description\": \"Main computer lab.\",\n  \"availabilityStart\": \"08:00:00\",\n  \"availabilityEnd\": \"18:00:00\",\n  \"availableDays\": \"MON,TUE,WED,THU,FRI\",\n  \"status\": \"ACTIVE\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/resources",
          "protocol": "http",
          "host": [ "localhost" ],
          "port": "8080",
          "path": [ "api", "v1", "resources" ]
        }
      }
    },
